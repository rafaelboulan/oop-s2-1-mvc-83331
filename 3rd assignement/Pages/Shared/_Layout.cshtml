<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - _3rd_assignement</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/_3rd_assignement.styles.css" asp-append-version="true" />
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">

                <a class="navbar-brand" asp-page="/Index">_3rd_assignement</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Privacy">Privacy</a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            @* ADMIN *@
                            if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-page="/Students/Index">Students</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-page="/Courses/Index">Courses</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-page="/Enrollments/Index">Enrollments</a>
                                </li>
                            }

                            @* INSTITUTION *@
                            if (User.IsInRole("Institution"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-page="/Courses/Index">Courses</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-page="/Enrollments/Index">Validate Enrollments</a>
                                </li>
                            }

                            @* STUDENT *@
                            if (User.IsInRole("Student"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-page="/Courses/Index">Courses</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-page="/Enrollments/Index">My Enrollments</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-page="/Enrollments/Request">Request Enrollment</a>
                                </li>
                            }
                        }

                    </ul>

                    <partial name="_LoginPartial" />

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - _3rd_assignement -
            <a asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>